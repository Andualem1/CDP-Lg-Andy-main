generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RoleKey {
  SUPER_ADMIN
  PLATFORM_ADMIN
  COURSE_CREATOR
  COURSE_REVIEWER
  FACILITATOR
  CSO_FOCAL_PERSON
  PARTICIPANT
  ME_VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DEACTIVATED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum OrganizationFormalityStatus {
  FORMAL_REGISTERED
  INFORMAL
  COMMUNITY_BASED
  UNKNOWN
  NOT_APPLICABLE
}

enum CourseStatus {
  DRAFT
  READY_FOR_REVIEW
  RETURNED_FOR_REVISION
  APPROVED
  PUBLISHED
  UNPUBLISHED
  ARCHIVED
}

enum CourseLevel {
  INTRODUCTORY
  FOUNDATIONAL
  INTERMEDIATE
  ADVANCED
  MIXED
}

enum CourseVisibility {
  PUBLIC
  ASSIGNED_ONLY
  PRIVATE
}

enum EnrollmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  WITHDRAWN
  ARCHIVED
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ContentBlockType {
  TEXT
  VIDEO
  AUDIO
  IMAGE
  RESOURCE
  EXTERNAL_LINK
  CASE_STUDY
  REFLECTION_PROMPT
  KEY_MESSAGE
  ACCORDION
  FLASHCARD
  BUTTON_CTA
  KNOWLEDGE_CHECK
  MULTIPLE_CHOICE_QUESTION
  TRUE_FALSE_QUESTION
  SHORT_ANSWER_PROMPT
  BRANCHING_SCENARIO
  PRACTICAL_ACTIVITY_PROMPT
}

enum QuizQuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  PASSED
  FAILED
  EXPIRED
}

enum CertificateStatus {
  ISSUED
  REVOKED
  EXPIRED
}

enum FeedbackType {
  COURSE_FEEDBACK
  LESSON_FEEDBACK
  PLATFORM_FEEDBACK
  PILOT_FEEDBACK
}

enum AuditActionType {
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  ROLE_ASSIGNED
  ROLE_REMOVED
  ORGANIZATION_CREATED
  ORGANIZATION_UPDATED
  COHORT_CREATED
  COHORT_UPDATED
  COURSE_CREATED
  COURSE_UPDATED
  COURSE_STATUS_CHANGED
  COURSE_SUBMITTED_FOR_REVIEW
  COURSE_RETURNED_FOR_REVISION
  COURSE_APPROVED
  COURSE_PUBLISHED
  COURSE_UNPUBLISHED
  COURSE_ARCHIVED
  CERTIFICATE_ISSUED
  CERTIFICATE_REVOKED
  REFERENCE_DATA_UPDATED
  LOGIN
  LOGOUT
}

model User {
  id                           String               @id @default(cuid())
  fullName                     String
  email                        String               @unique
  passwordHash                 String?
  authProviderId               String?
  status                       UserStatus           @default(ACTIVE)
  phone                        String?
  jobTitle                     String?
  department                   String?
  preferredLanguage            String?
  region                       String?
  profilePhotoUrl              String?
  organizationId               String?
  primaryCohortId              String?
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
  lastLoginAt                  DateTime?
  organization                 Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  primaryCohort                Cohort?              @relation(fields: [primaryCohortId], references: [id], onDelete: SetNull)
  roleAssignments              UserRoleAssignment[] @relation("UserRoleAssignments")
  rolesAssigned                UserRoleAssignment[] @relation("RoleAssignedBy")
  createdCourses               Course[]             @relation("CourseCreatedBy")
  assignedCourses              Course[]             @relation("CourseAssignedCreator")
  createdCourseVersions        CourseVersion[]      @relation("CourseVersionCreatedBy")
  publishedCourseVersions      CourseVersion[]      @relation("CourseVersionPublishedBy")
  uploadedResources            Resource[]           @relation("ResourceUploadedBy")
  assignedCourseAssignments    CourseAssignment[]   @relation("CourseAssignmentAssignedBy")
  targetedCourseAssignments    CourseAssignment[]   @relation("CourseAssignmentTargetUser")
  enrollments                  Enrollment[]
  quizAttempts                 QuizAttempt[]
  certificates                 Certificate[]
  feedback                     Feedback[]
  auditLogs                    AuditLog[]           @relation("AuditLogActor")
  invitationsSent              OnboardingInvitation[] @relation("InvitationCreatedBy")

  @@index([organizationId])
  @@index([primaryCohortId])
  @@index([status])
}

model Role {
  id              String               @id @default(cuid())
  key             RoleKey              @unique
  name            String
  description     String?
  isSystemRole    Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  userAssignments UserRoleAssignment[]
}

model UserRoleAssignment {
  id           String    @id @default(cuid())
  userId       String
  roleId       String
  assignedById String
  assignedAt   DateTime  @default(now())
  isActive     Boolean   @default(true)
  scopeType    String?
  scopeId      String?
  expiresAt    DateTime?
  user         User      @relation("UserRoleAssignments", fields: [userId], references: [id], onDelete: Cascade)
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  assignedBy   User      @relation("RoleAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([userId, roleId])
  @@index([assignedById])
  @@index([isActive])
}

model Organization {
  id                 String                       @id @default(cuid())
  name               String                       @unique
  status             OrganizationStatus           @default(ACTIVE)
  shortName          String?
  region             String?
  zone               String?
  woreda             String?
  organizationTypeId String?
  formalityStatus    OrganizationFormalityStatus  @default(UNKNOWN)
  registrationNumber String?
  focalPersonName    String?
  focalPersonEmail   String?
  focalPersonPhone   String?
  notes              String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  users              User[]
  cohortLinks        CohortOrganization[]
  courseAssignments  CourseAssignment[]           @relation("CourseAssignmentTargetOrganization")

  @@index([status])
  @@index([region])
  @@index([organizationTypeId])
}

model Cohort {
  id                String               @id @default(cuid())
  name              String               @unique
  status            OrganizationStatus   @default(ACTIVE)
  startDate         DateTime?
  endDate           DateTime?
  description       String?
  programmeName     String?
  region            String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  users             User[]
  organizationLinks CohortOrganization[]
  courseAssignments CourseAssignment[]   @relation("CourseAssignmentTargetCohort")

  @@index([status])
  @@index([region])
}

model CohortOrganization {
  id             String       @id @default(cuid())
  cohortId       String
  organizationId String
  createdAt      DateTime     @default(now())
  cohort         Cohort       @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([cohortId, organizationId])
  @@index([organizationId])
}

model CapacityArea {
  id          String               @id @default(cuid())
  name        String               @unique
  slug        String               @unique
  description String?
  isActive    Boolean              @default(true)
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  courses     CourseCapacityArea[]
  practices   CSOPractice[]
  indicators  Indicator[]

  @@index([isActive])
  @@index([sortOrder])
}

model CSOPractice {
  id             String       @id
  capacityAreaId String
  name           String
  description    String?
  exampleGap     String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  capacityArea   CapacityArea @relation(fields: [capacityAreaId], references: [id], onDelete: Restrict)
  indicators     Indicator[]

  @@index([capacityAreaId])
  @@index([isActive])
}

model StandardFamily {
  id          String      @id
  name        String
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  indicators  Indicator[]

  @@index([isActive])
}

model Indicator {
  id                   String         @id
  standardFamilyId     String
  indicatorCode        String
  indicatorName        String
  indicatorDescription String?
  capacityAreaId       String
  csoPracticeId        String?
  measurementLevel     String?
  evidenceType         String?
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  standardFamily       StandardFamily @relation(fields: [standardFamilyId], references: [id], onDelete: Restrict)
  capacityArea         CapacityArea   @relation(fields: [capacityAreaId], references: [id], onDelete: Restrict)
  csoPractice          CSOPractice?   @relation(fields: [csoPracticeId], references: [id], onDelete: Restrict)

  @@index([standardFamilyId])
  @@index([capacityAreaId])
  @@index([csoPracticeId])
  @@index([isActive])
}

model Course {
  id                          String               @id @default(cuid())
  title                       String
  slug                        String               @unique
  shortDescription            String
  longDescription             String?
  targetAudience              String?
  language                    String               @default("English")
  level                       CourseLevel          @default(FOUNDATIONAL)
  visibility                  CourseVisibility     @default(PRIVATE)
  status                      CourseStatus         @default(DRAFT)
  certificateEligible         Boolean              @default(false)
  finalTestRequired           Boolean              @default(false)
  defaultPassThreshold        Int                  @default(80)
  estimatedDurationMinutes    Int?
  targetCsoProfile            String?
  capacityGapAddressed        String?
  intendedPracticeImprovement String?
  recommendedPrerequisites    String?
  relatedFollowUpSupport      String?
  coverImageUrl               String?
  analysisMetadataJson        Json?
  createdById                 String
  assignedCreatorId           String
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  archivedAt                  DateTime?
  createdBy                   User                 @relation("CourseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  assignedCreator             User                 @relation("CourseAssignedCreator", fields: [assignedCreatorId], references: [id], onDelete: Restrict)
  versions                    CourseVersion[]
  capacityAreas               CourseCapacityArea[]
  learningOutcomes            LearningOutcome[]
  assignments                 CourseAssignment[]
  enrollments                 Enrollment[]
  resources                   Resource[]
  quizAttempts                QuizAttempt[]
  certificates                Certificate[]
  feedback                    Feedback[]

  @@index([status])
  @@index([visibility])
  @@index([level])
  @@index([createdById])
  @@index([assignedCreatorId])
}

model CourseCapacityArea {
  id             String       @id @default(cuid())
  courseId       String
  capacityAreaId String
  createdAt      DateTime     @default(now())
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  capacityArea   CapacityArea @relation(fields: [capacityAreaId], references: [id], onDelete: Restrict)

  @@unique([courseId, capacityAreaId])
  @@index([capacityAreaId])
}

model LearningOutcome {
  id            String                        @id @default(cuid())
  courseId      String
  statement     String
  order         Int
  moduleId      String?
  lessonId      String?
  alignmentMetadataJson Json?
  createdAt     DateTime                      @default(now())
  updatedAt     DateTime                      @updatedAt
  course        Course                        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module        Module?                       @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  lesson        Lesson?                       @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  quizQuestions QuizQuestionLearningOutcome[]

  @@unique([courseId, order])
  @@index([moduleId])
  @@index([lessonId])
}

model CourseVersion {
  id            String       @id @default(cuid())
  courseId      String
  versionNumber Int
  status        CourseStatus @default(DRAFT)
  changeNotes   String?
  createdById   String
  publishedById String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  publishedAt   DateTime?
  archivedAt    DateTime?
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy     User         @relation("CourseVersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  publishedBy   User?        @relation("CourseVersionPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  modules       Module[]
  resources     Resource[]
  quizzes       Quiz[]
  enrollments   Enrollment[]
  quizAttempts  QuizAttempt[]
  certificates  Certificate[]

  @@unique([courseId, versionNumber])
  @@index([status])
  @@index([createdById])
  @@index([publishedById])
}

model Module {
  id                       String            @id @default(cuid())
  courseVersionId          String
  title                    String
  description              String?
  order                    Int
  estimatedDurationMinutes Int?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  courseVersion            CourseVersion     @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  lessons                  Lesson[]
  learningOutcomes         LearningOutcome[]

  @@unique([courseVersionId, order])
}

model Lesson {
  id                       String                 @id @default(cuid())
  moduleId                 String
  title                    String
  description              String?
  order                    Int
  estimatedDurationMinutes Int?
  completionRequired       Boolean                @default(true)
  completionRule           String?
  alignmentMetadataJson    Json?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  module                   Module                 @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  contentBlocks            ContentBlock[]
  lessonProgress           LessonProgress[]
  learningOutcomes         LearningOutcome[]
  feedback                 Feedback[]

  @@unique([moduleId, order])
}

model ContentBlock {
  id                       String           @id @default(cuid())
  lessonId                 String
  type                     ContentBlockType
  title                    String
  order                    Int
  configJson               Json
  isRequired               Boolean          @default(true)
  estimatedDurationMinutes Int?
  accessibilityNotes       String?
  hasAccessibilityWarning  Boolean          @default(false)
  resourceId               String?
  quizQuestionId           String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  lesson                   Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  resource                 Resource?        @relation(fields: [resourceId], references: [id], onDelete: SetNull)
  quizQuestion             QuizQuestion?    @relation(fields: [quizQuestionId], references: [id], onDelete: SetNull)

  @@unique([lessonId, order])
  @@index([type])
  @@index([resourceId])
  @@index([quizQuestionId])
}

model Resource {
  id                   String         @id @default(cuid())
  courseId             String
  courseVersionId      String
  title                String
  description          String?
  fileUrl              String
  fileName             String
  fileType             String
  fileSizeBytes        Int?
  downloadLabel        String
  accessibilityChecked Boolean        @default(false)
  accessibilityNotes   String?
  uploadedById         String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  archivedAt           DateTime?
  course               Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersion        CourseVersion  @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  uploadedBy           User           @relation("ResourceUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  contentBlocks        ContentBlock[]

  @@index([courseId])
  @@index([courseVersionId])
  @@index([uploadedById])
  @@index([archivedAt])
}

model Quiz {
  id              String         @id @default(cuid())
  courseVersionId String
  title           String
  description     String?
  isFinalTest     Boolean        @default(false)
  passThreshold   Int            @default(80)
  retakeAllowed   Boolean        @default(true)
  maxAttempts     Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  courseVersion   CourseVersion  @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  questions       QuizQuestion[]
  attempts        QuizAttempt[]

  @@index([courseVersionId])
  @@index([isFinalTest])
}

model QuizQuestion {
  id               String                        @id @default(cuid())
  quizId           String
  type             QuizQuestionType
  questionText     String
  order            Int
  points           Int                           @default(1)
  explanation      String?
  configJson       Json
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  quiz             Quiz                          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  contentBlocks    ContentBlock[]
  learningOutcomes QuizQuestionLearningOutcome[]

  @@unique([quizId, order])
  @@index([type])
}

model QuizQuestionLearningOutcome {
  id                String          @id @default(cuid())
  quizQuestionId    String
  learningOutcomeId String
  createdAt         DateTime        @default(now())
  quizQuestion      QuizQuestion    @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)
  learningOutcome   LearningOutcome @relation(fields: [learningOutcomeId], references: [id], onDelete: Cascade)

  @@unique([quizQuestionId, learningOutcomeId])
  @@index([learningOutcomeId])
}

model QuizAttempt {
  id              String            @id @default(cuid())
  quizId          String
  userId          String
  courseId        String
  courseVersionId String
  status          QuizAttemptStatus @default(IN_PROGRESS)
  score           Int?
  maxScore        Int?
  percentage      Float?
  passed          Boolean           @default(false)
  answersJson     Json?
  startedAt       DateTime          @default(now())
  submittedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  quiz            Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersion   CourseVersion     @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  certificates    Certificate[]

  @@index([quizId])
  @@index([userId])
  @@index([courseId])
  @@index([courseVersionId])
  @@index([status])
}

model CourseAssignment {
  id                   String        @id @default(cuid())
  courseId             String
  assignedById         String
  assignedAt           DateTime      @default(now())
  assignmentType       String
  targetUserId         String?
  targetCohortId       String?
  targetOrganizationId String?
  dueDate              DateTime?
  isActive             Boolean       @default(true)
  course               Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  assignedBy           User          @relation("CourseAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: Restrict)
  targetUser           User?         @relation("CourseAssignmentTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetCohort         Cohort?       @relation("CourseAssignmentTargetCohort", fields: [targetCohortId], references: [id], onDelete: Cascade)
  targetOrganization   Organization? @relation("CourseAssignmentTargetOrganization", fields: [targetOrganizationId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([assignedById])
  @@index([targetUserId])
  @@index([targetCohortId])
  @@index([targetOrganizationId])
  @@index([isActive])
}

model Enrollment {
  id              String             @id @default(cuid())
  userId          String
  courseId        String
  courseVersionId String
  status          EnrollmentStatus   @default(NOT_STARTED)
  progressPercent Int                @default(0)
  enrolledAt      DateTime           @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  lastAccessedAt  DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersion   CourseVersion      @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  lessonProgress  LessonProgress[]
  certificates    Certificate[]

  @@unique([userId, courseVersionId])
  @@index([courseId])
  @@index([status])
  @@index([lastAccessedAt])
}

model LessonProgress {
  id             String               @id @default(cuid())
  enrollmentId   String
  lessonId       String
  status         LessonProgressStatus @default(NOT_STARTED)
  progressJson   Json?
  startedAt      DateTime?
  completedAt    DateTime?
  lastAccessedAt DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  enrollment     Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
  @@index([status])
}

model Certificate {
  id                      String            @id @default(cuid())
  certificateCode         String            @unique
  userId                  String
  courseId                String
  courseVersionId         String
  enrollmentId            String
  quizAttemptId           String
  status                  CertificateStatus @default(ISSUED)
  issuedAt                DateTime          @default(now())
  revokedAt               DateTime?
  pdfUrl                  String?
  participantNameSnapshot String?
  courseTitleSnapshot     String?
  issuerNameSnapshot      String?
  completionDate          DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                  Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseVersion           CourseVersion     @relation(fields: [courseVersionId], references: [id], onDelete: Cascade)
  enrollment              Enrollment        @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  quizAttempt             QuizAttempt       @relation(fields: [quizAttemptId], references: [id], onDelete: Restrict)

  @@unique([userId, courseVersionId])
  @@index([courseId])
  @@index([courseVersionId])
  @@index([enrollmentId])
  @@index([quizAttemptId])
  @@index([status])
}

model CertificateTemplate {
  id             String   @id @default(cuid())
  name           String
  issuerName     String
  signatoryName  String?
  signatoryTitle String?
  logoUrl        String?
  footerText     String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isDefault])
}

model Feedback {
  id                 String       @id @default(cuid())
  type               FeedbackType @default(COURSE_FEEDBACK)
  userId             String
  courseId           String?
  lessonId           String?
  rating             Int?
  usefulnessRating   Int?
  clarityRating      Int?
  accessibilityIssue Boolean      @default(false)
  comment            String?
  createdAt          DateTime     @default(now())
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  course             Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson             Lesson?      @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([userId])
  @@index([courseId])
  @@index([lessonId])
}

model AuditLog {
  id           String          @id @default(cuid())
  actorUserId  String
  actionType   AuditActionType
  entityType   String
  entityId     String
  description  String
  metadataJson Json?
  createdAt    DateTime        @default(now())
  actor        User            @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId])
  @@index([actionType])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ReferenceDataItem {
  id          String   @id @default(cuid())
  category    String
  key         String
  label       String
  description String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([category, key])
  @@index([category])
  @@index([isActive])
}

model OnboardingInvitation {
  id          String    @id @default(cuid())
  email       String    @unique
  role        RoleKey
  tokenHash   String    @unique
  expiresAt   DateTime
  invitedByUserId String
  usedAt      DateTime?
  attemptCount Int      @default(0)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  invitedBy   User      @relation("InvitationCreatedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([tokenHash])
  @@index([email])
  @@index([invitedByUserId])
}
