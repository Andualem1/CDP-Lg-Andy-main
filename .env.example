# PostgreSQL database for Prisma.
# Use a local Postgres database for development, or the pooled Vercel/Neon/Supabase URL in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cso_learning_hub?schema=public"

# Placeholder for the local auth/session foundation planned in a later slice.
SESSION_SECRET="replace-with-a-long-random-local-development-secret"

# Public app URL used by auth callbacks, emails, and absolute links when needed.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# External HRBA course app iframe integration.
# Use http://localhost:5173 while running the Vite app locally, or the deployed Vercel URL in production.
HRBA_EXTERNAL_COURSE_URL="https://pilot-hrba-e-learn-v1-wajj.vercel.app"
HRBA_EXTERNAL_COURSE_ALLOWED_ORIGINS="https://pilot-hrba-e-learn-v1-wajj.vercel.app,http://localhost:5173"

# SMTP configuration for invitation emails.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="replace-with-smtp-username"
SMTP_PASS="replace-with-smtp-password"
SMTP_SECURE="false"
EMAIL_FROM="CSO Learning Hub <no-reply@example.com>"
